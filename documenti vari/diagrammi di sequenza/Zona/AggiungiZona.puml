@startuml
actor Utente
participant Form <<boundary>>
participant GestoreZone <<control>>
participant Zona <<entity>>

Utente -> Form : seleziona "Aggiungi Zona"
activate Form

Utente -> Form : inserisce l'ID della zona
Utente -> Form : inserisce il nome per la zona

Form -> GestoreZone : creaZona()
activate GestoreZone

GestoreZone -> Zona ** : <<crea>>
activate Zona
Zona --> GestoreZone
deactivate Zona

GestoreZone --> Form : zona generata
deactivate GestoreZone

Form --> Utente : zona creata con successo
deactivate Form
@enduml