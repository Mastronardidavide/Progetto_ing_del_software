@startuml
actor Utente
participant Form <<boundary>>
participant GestoreZone <<control>>

Utente -> Form : seleziona "Rinomina Zona"
activate Form

Utente -> Form : inserisce l'ID della zona da rinominare
Utente -> Form : inserisce il nuovo nome della zona

Form -> GestoreZone : modificaZona(id, nuovoNome)
activate GestoreZone

GestoreZone --> Form : restituisce stringa di conferma
deactivate GestoreZone

Form --> Utente : zona rinominata con successo
deactivate Form
@enduml