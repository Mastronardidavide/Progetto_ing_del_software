@startuml
actor Utente
participant Form <<boundary>>
participant GestoreZone <<control>>

Utente -> Form : seleziona "Lista Zone"
activate Form

Form -> GestoreZone : listaZone()
activate GestoreZone

GestoreZone --> Form : restituisce la lista delle zone
deactivate GestoreZone

Form --> Utente : visualizza le zone registrate
deactivate Form
@enduml