@startuml eseguiscenario
title Esegui scenario

start
if (Admin autenticato?) then (no)
    :Mostra messaggio di errore;
    :Richiedi autenticazione;  
    
else (si)
    if (Scenario esiste) then (si)
        :Seleziona uno scenario da eseguire;
        :Attiva eventuali attuatori;
        :Gli attuatori sono attivati;
    else (no)
        :Mostra messaggio di errore;
    endif
endif
stop
@enduml